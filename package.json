{
  "name": "reach-for-the-sky",
  "version": "1.0.1",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "copywasm": "node scripts/copy-sql-wasm.mjs",
    "dev": "vite",
    "build": "pnpm copywasm && tsc --noEmit && vite build",
    "build:android": "CAPACITOR=true pnpm build && pnpm exec cap sync android",
    "cap:sync": "pnpm exec cap sync",
    "cap:sync:android": "pnpm exec cap sync android",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "verify:render-stats": "node scripts/verify-render-stats.mjs",
    "verify:build-flow": "node scripts/verify-build-flow.mjs",
    "verify:campaign-flow": "node scripts/verify-campaign-flow.mjs",
    "verify:browser": "pnpm verify:browser:core && pnpm verify:browser:persistence && pnpm verify:browser:public && pnpm verify:browser:metadata",
    "verify:browser:core": "pnpm verify:render-stats && pnpm verify:build-flow && pnpm verify:campaign-flow && pnpm verify:mobile-build-flow",
    "verify:browser:persistence": "pnpm verify:save-load && pnpm verify:corrupt-save && pnpm verify:preferences && pnpm verify:report-loop",
    "verify:browser:public": "pnpm verify:public-memory && pnpm verify:memory-repair && pnpm verify:invite-visit && pnpm verify:visit-lifecycle",
    "verify:browser:metadata": "pnpm verify:menu-scenarios && pnpm verify:audio-assets && pnpm verify:app-metadata && pnpm verify:console-clean",
    "verify:release": "pnpm lint && pnpm typecheck && pnpm test && pnpm build && pnpm verify:browser && pnpm capture:screenshots && pnpm cap:sync:android",
    "verify:save-load": "node scripts/verify-save-load.mjs",
    "verify:corrupt-save": "node scripts/verify-corrupt-save.mjs",
    "verify:preferences": "node scripts/verify-preferences.mjs",
    "verify:report-loop": "node scripts/verify-report-loop.mjs",
    "verify:menu-scenarios": "node scripts/verify-menu-scenarios.mjs",
    "capture:screenshots": "node scripts/capture-screenshots.mjs",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "typecheck": "tsc --noEmit",
    "verify:mobile-build-flow": "node scripts/verify-mobile-build-flow.mjs",
    "verify:audio-assets": "node scripts/verify-audio-assets.mjs",
    "verify:app-metadata": "node scripts/verify-app-metadata.mjs",
    "verify:public-memory": "node scripts/verify-public-memory.mjs",
    "verify:memory-repair": "node scripts/verify-memory-repair.mjs",
    "verify:invite-visit": "node scripts/verify-invite-visit.mjs",
    "verify:visit-lifecycle": "node scripts/verify-visit-lifecycle.mjs",
    "verify:console-clean": "node scripts/verify-console-clean.mjs"
  },
  "dependencies": {
    "@capacitor-community/sqlite": "^8.1.0",
    "@capacitor/android": "^8.3.1",
    "@capacitor/app": "^8.1.0",
    "@capacitor/core": "^8.3.1",
    "@capacitor/haptics": "^8.0.2",
    "@capacitor/ios": "^8.3.1",
    "@capacitor/preferences": "^8.0.1",
    "@capacitor/status-bar": "^8.0.2",
    "howler": "^2.2.4",
    "jeep-sqlite": "^2.8.0",
    "koota": "^0.6.6",
    "pixi-viewport": "^6.0.3",
    "pixi.js": "^8.18.1",
    "solid-js": "^1.9.12",
    "solid-pixi": "^1.0.0",
    "sql.js": "1.11.0",
    "three": "^0.184.0",
    "tone": "^15.1.22",
    "yuka": "^0.7.8"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.12",
    "@capacitor/cli": "^8.3.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@types/howler": "^2.2.12",
    "@types/node": "^25.6.0",
    "@types/three": "^0.184.0",
    "jsdom": "^29.0.2",
    "typescript": "^6.0.3",
    "vite": "^8.0.9",
    "vite-plugin-solid": "^2.11.12",
    "vitest": "^4.1.5"
  }
}
